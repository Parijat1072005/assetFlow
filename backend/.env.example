# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/assetflow?schema=public"

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bootstrap admin (created by seed script if no admin exists)
BOOTSTRAP_ADMIN_NAME="System Admin"
BOOTSTRAP_ADMIN_EMAIL=admin@assetflow.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
