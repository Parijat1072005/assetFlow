// =============================================================================
// AssetFlow — Enterprise Asset & Resource Management System
// Prisma schema — PostgreSQL
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum Role {
  EMPLOYEE
  DEPARTMENT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  TRANSFERRED
}

enum HolderType {
  EMPLOYEE
  DEPARTMENT
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  PLANNED
  IN_PROGRESS
  CLOSED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

enum NotificationType {
  ASSET_ASSIGNED
  MAINTENANCE_APPROVED
  MAINTENANCE_REJECTED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  TRANSFER_APPROVED
  TRANSFER_REJECTED
  OVERDUE_RETURN
  AUDIT_DISCREPANCY
  AUDIT_ASSIGNED
  GENERAL
}

// -----------------------------------------------------------------------------
// CORE IDENTITY
// -----------------------------------------------------------------------------

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(EMPLOYEE)
  status       UserStatus @default(ACTIVE)
  departmentId String?
  department   Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])
  phone        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  headOfDepartments      Department[]          @relation("DepartmentHead")
  registeredAssets       Asset[]               @relation("AssetRegisteredBy")
  allocationsAsHolder    Allocation[]          @relation("AllocationHolderEmployee")
  allocationsCreated     Allocation[]          @relation("AllocationCreatedBy")
  transfersFrom          TransferRequest[]     @relation("TransferFromEmployee")
  transfersTo            TransferRequest[]     @relation("TransferToEmployee")
  transfersDecidedBy     TransferRequest[]     @relation("TransferDecidedBy")
  bookingsRequested      Booking[]             @relation("BookingRequestedBy")
  maintenanceRaised      MaintenanceRequest[]  @relation("MaintenanceRaisedBy")
  maintenanceDecidedBy   MaintenanceRequest[]  @relation("MaintenanceDecidedBy")
  maintenanceTechnician  MaintenanceRequest[]  @relation("MaintenanceTechnician")
  auditCyclesCreated     AuditCycle[]          @relation("AuditCycleCreatedBy")
  auditorAssignments     AuditorAssignment[]
  auditItemsVerified     AuditItem[]           @relation("AuditItemVerifiedBy")
  notifications          Notification[]
  activityLogs           ActivityLog[]
  refreshTokens          RefreshToken[]

  @@index([departmentId])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  @@index([userId])
}

// -----------------------------------------------------------------------------
// ORGANIZATION SETUP
// -----------------------------------------------------------------------------

model Department {
  id               String            @id @default(uuid())
  name             String            @unique
  headId           String?
  head             User?             @relation("DepartmentHead", fields: [headId], references: [id])
  parentDeptId     String?
  parentDept       Department?       @relation("DepartmentHierarchy", fields: [parentDeptId], references: [id])
  childDepartments Department[]      @relation("DepartmentHierarchy")
  status           DepartmentStatus  @default(ACTIVE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  members          User[]            @relation("DepartmentMembers")
  assets           Asset[]           @relation("AssetDepartment")
  allocationsHeld  Allocation[]      @relation("AllocationHolderDepartment")
  auditCycles      AuditCycle[]

  @@index([parentDeptId])
}

model AssetCategory {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  // Category-specific optional fields (e.g. { "warrantyPeriodMonths": true }) stored as
  // a JSON schema describing which extra fields apply to assets in this category.
  customFields  Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assets        Asset[]

  @@index([name])
}

// -----------------------------------------------------------------------------
// ASSETS
// -----------------------------------------------------------------------------

model Asset {
  id               String         @id @default(uuid())
  assetTag         String         @unique // e.g. AF-0001, auto-generated
  name             String
  categoryId       String
  category         AssetCategory  @relation(fields: [categoryId], references: [id])
  serialNumber     String?        @unique
  qrCode           String?        @unique
  acquisitionDate  DateTime?
  acquisitionCost  Decimal?       @db.Decimal(12, 2)
  condition        AssetCondition @default(GOOD)
  status           AssetStatus    @default(AVAILABLE)
  location         String?
  departmentId     String?
  department       Department?    @relation("AssetDepartment", fields: [departmentId], references: [id])
  isBookable       Boolean        @default(false)
  photoUrl         String?
  documentUrls     String[]       @default([])
  customFieldValues Json?
  registeredById   String
  registeredBy     User           @relation("AssetRegisteredBy", fields: [registeredById], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  allocations          Allocation[]
  transferRequests      TransferRequest[]
  bookings              Booking[]
  maintenanceRequests    MaintenanceRequest[]
  auditItems             AuditItem[]

  @@index([categoryId])
  @@index([departmentId])
  @@index([status])
  @@index([assetTag])
}

// -----------------------------------------------------------------------------
// ALLOCATION & TRANSFER
// -----------------------------------------------------------------------------

model Allocation {
  id                  String            @id @default(uuid())
  assetId             String
  asset               Asset             @relation(fields: [assetId], references: [id])
  holderType          HolderType
  holderEmployeeId    String?
  holderEmployee      User?             @relation("AllocationHolderEmployee", fields: [holderEmployeeId], references: [id])
  holderDepartmentId  String?
  holderDepartment    Department?       @relation("AllocationHolderDepartment", fields: [holderDepartmentId], references: [id])
  allocatedDate       DateTime          @default(now())
  expectedReturnDate  DateTime?
  actualReturnDate    DateTime?
  status              AllocationStatus  @default(ACTIVE)
  checkInCondition    AssetCondition?
  checkInNotes        String?
  createdById         String
  createdBy           User              @relation("AllocationCreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  transferRequests    TransferRequest[]

  @@index([assetId])
  @@index([status])
  @@index([holderEmployeeId])
  @@index([expectedReturnDate])
}

model TransferRequest {
  id               String         @id @default(uuid())
  assetId          String
  asset            Asset          @relation(fields: [assetId], references: [id])
  currentAllocationId String?
  currentAllocation Allocation?   @relation(fields: [currentAllocationId], references: [id])
  fromEmployeeId   String?
  fromEmployee     User?          @relation("TransferFromEmployee", fields: [fromEmployeeId], references: [id])
  toEmployeeId     String
  toEmployee       User           @relation("TransferToEmployee", fields: [toEmployeeId], references: [id])
  reason           String
  status           TransferStatus @default(REQUESTED)
  decidedById      String?
  decidedBy        User?          @relation("TransferDecidedBy", fields: [decidedById], references: [id])
  decidedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([assetId])
  @@index([status])
}

// -----------------------------------------------------------------------------
// RESOURCE BOOKING
// -----------------------------------------------------------------------------

model Booking {
  id             String        @id @default(uuid())
  assetId        String
  asset          Asset         @relation(fields: [assetId], references: [id])
  requestedById  String
  requestedBy    User          @relation("BookingRequestedBy", fields: [requestedById], references: [id])
  purpose        String?
  startTime      DateTime
  endTime        DateTime
  status         BookingStatus @default(UPCOMING)
  cancelledReason String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([assetId, startTime, endTime])
  @@index([status])
}

// -----------------------------------------------------------------------------
// MAINTENANCE
// -----------------------------------------------------------------------------

model MaintenanceRequest {
  id             String              @id @default(uuid())
  assetId        String
  asset          Asset               @relation(fields: [assetId], references: [id])
  raisedById     String
  raisedBy       User                @relation("MaintenanceRaisedBy", fields: [raisedById], references: [id])
  issueDescription String
  priority       MaintenancePriority @default(MEDIUM)
  photoUrl       String?
  status         MaintenanceStatus   @default(PENDING)
  decidedById    String?
  decidedBy      User?               @relation("MaintenanceDecidedBy", fields: [decidedById], references: [id])
  decidedAt      DateTime?
  rejectionReason String?
  technicianId   String?
  technician     User?               @relation("MaintenanceTechnician", fields: [technicianId], references: [id])
  technicianNote String?
  resolvedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([assetId])
  @@index([status])
}

// -----------------------------------------------------------------------------
// AUDIT
// -----------------------------------------------------------------------------

model AuditCycle {
  id             String            @id @default(uuid())
  name           String
  departmentId   String?
  department     Department?       @relation(fields: [departmentId], references: [id])
  locationScope  String?
  startDate      DateTime
  endDate        DateTime
  status         AuditCycleStatus  @default(PLANNED)
  createdById    String
  createdBy      User              @relation("AuditCycleCreatedBy", fields: [createdById], references: [id])
  closedAt       DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  auditors       AuditorAssignment[]
  items          AuditItem[]

  @@index([status])
}

model AuditorAssignment {
  id           String    @id @default(uuid())
  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  auditorId    String
  auditor      User       @relation(fields: [auditorId], references: [id])
  assignedAt   DateTime   @default(now())

  @@unique([auditCycleId, auditorId])
}

model AuditItem {
  id               String              @id @default(uuid())
  auditCycleId     String
  auditCycle       AuditCycle          @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  assetId          String
  asset            Asset               @relation(fields: [assetId], references: [id])
  expectedLocation String?
  verification     VerificationStatus  @default(PENDING)
  notes            String?
  verifiedById     String?
  verifiedBy       User?               @relation("AuditItemVerifiedBy", fields: [verifiedById], references: [id])
  verifiedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([auditCycleId, assetId])
  @@index([verification])
}

// -----------------------------------------------------------------------------
// NOTIFICATIONS & ACTIVITY LOG
// -----------------------------------------------------------------------------

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

model ActivityLog {
  id         String   @id @default(uuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  action     String   // e.g. "ASSET_REGISTERED", "MAINTENANCE_APPROVED"
  entityType String   // e.g. "Asset", "Booking"
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}
